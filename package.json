{
  "name": "codesurf",
  "version": "0.1.0",
  "productName": "CodeSurf",
  "description": "Infinite canvas workspace for AI agents",
  "main": "dist-electron/main/index.js",
  "bin": {
    "codesurf": "bin/codesurf.cjs",
    "codesurfd": "bin/codesurfd.mjs"
  },
  "files": [
    "bin/",
    "dist-electron/",
    "packages/contex-relay/dist/",
    "packages/codesurf-dreaming/",
    "packages/codesurf-daemon/",
    "resources/",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "test": "node --test test/*.test.ts test/*.test.mjs test/main/*.test.mjs test/sidebar/*.test.mjs test/daemon/*.test.mjs",
    "test:daemon": "node --test test/daemon/*.test.mjs",
    "typecheck": "npm run typecheck:go",
    "typecheck:tsc": "tsc -p tsconfig.json --noEmit",
    "typecheck:go": "tsgo -p tsconfig.tsgo.json --noEmit",
    "typecheck:go:watch": "tsgo -p tsconfig.tsgo.json --noEmit --watch --pretty false",
    "dev": "node scripts/dev.js",
    "dev:go": "node scripts/dev-go.js",
    "perf:render": "node scripts/measure-render.js",
    "build:main": "cross-env EV_BUILD_TARGET=main electron-vite build",
    "build:preload": "cross-env EV_BUILD_TARGET=preload electron-vite build",
    "build:renderer": "cross-env EV_BUILD_TARGET=renderer electron-vite build",
    "build": "cross-env EV_BUILD_TARGET=main electron-vite build && cross-env EV_BUILD_TARGET=preload electron-vite build && cross-env EV_BUILD_TARGET=renderer electron-vite build",
    "build:npm": "bun run scripts/build-npm-package.mjs",
    "dist:mac": "npm run build && electron-builder --mac dmg zip",
    "release:mac": "node scripts/verify-mac-release-env.mjs && npm run build && electron-builder --mac dmg zip",
    "dist:windows": "npm run build && electron-builder --win nsis portable",
    "dist:linux": "npm run build && electron-builder --linux AppImage deb",
    "build:icon": "node scripts/create-ico.js",
    "release:github": "node scripts/verify-mac-release-env.mjs && npm run build && electron-builder --mac dmg zip --publish always",
    "dogfood": "electron-vite build && electron-vite preview",
    "preview": "electron-vite preview",
    "dev:electrobun": "npm run build:renderer && electrobun dev",
    "build:electrobun": "npm run build:renderer && electrobun build --targets=current",
    "run:electrobun": "electrobun run",
    "smoke:electrobun": "npm run build:electrobun && node scripts/smoke-electrobun.mjs",
    "acceptance:electrobun": "npm run build:electrobun && node scripts/accept-electrobun.mjs",
    "validate-extension": "node scripts/validate-extension.mjs",
    "rebuild": "node scripts/patch-node-pty-win.js && electron-rebuild -f -o better-sqlite3 && electron-rebuild -f -o node-pty",
    "postinstall": "node scripts/patch-node-pty-win.js && electron-rebuild -f -o better-sqlite3 && electron-rebuild -f -o node-pty"
  },
  "keywords": [],
  "author": "Jason",
  "license": "AGPL-3.0-only",
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/bun": "^1.3.8",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260504.1",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "cross-env": "^10.1.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.176",
    "@anthropic-ai/claude-agent-sdk": "^0.2.118",
    "@codesurf/daemon": "file:packages/codesurf-daemon",
    "@monaco-editor/react": "^4.7.0",
    "@opencode-ai/sdk": "^1.2.27",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@ricky0123/vad-web": "^0.0.30",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@types/better-sqlite3": "^7.6.13",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "ai": "^6.0.174",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "electrobun": "^1.16.0",
    "electron-updater": "^6.8.3",
    "elkjs": "^0.11.1",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^0.468.0",
    "morphcloud": "^0.0.20",
    "motion": "^12.38.0",
    "nanoid": "^5.1.11",
    "node-pty": "1.1.0",
    "onnxruntime-web": "^1.24.3",
    "radix-ui": "^1.4.3",
    "react-file-icon": "^1.5.0",
    "react-jsx-parser": "^2.4.1",
    "sharp": "^0.34.5",
    "shiki": "^4.0.2",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.5.0",
    "use-stick-to-bottom": "^1.1.4",
    "web-worker": "^1.3.0",
    "xterm": "^5.3.0"
  },
  "build": {
    "appId": "com.huggiapps.codesurf",
    "productName": "CodeSurf",
    "directories": {
      "buildResources": "resources",
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "bin/**/*",
      "packages/codesurf-dreaming/**/*",
      "packages/codesurf-daemon/**/*",
      "package.json",
      "resources/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/node-pty/**",
      "node_modules/sharp/**"
    ],
    "extraResources": [
      {
        "from": "examples/extensions/agent-kanban",
        "to": "bundled-extensions/agent-kanban"
      },
      {
        "from": "bundled-extensions",
        "to": "bundled-extensions",
        "filter": [
          "**/*",
          "!agent-kanban",
          "!agent-kanban/**"
        ]
      }
    ],
    "beforeBuild": "scripts/before-build.js",
    "icon": "resources/icon.png",
    "fileAssociations": [
      {
        "ext": "skill",
        "name": "Claude Skill",
        "description": "Claude agent skill bundle",
        "role": "Viewer",
        "icon": "resources/icon.png"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "resources/icon.png",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "gatekeeperAssess": false,
      "notarize": true,
      "forceCodeSigning": true,
      "extendInfo": {
        "NSMicrophoneUsageDescription": "CodeSurf uses the microphone for voice dictation and agent voice features.",
        "NSCameraUsageDescription": "CodeSurf uses the camera for workspace browser and extension surfaces that request camera access."
      }
    },
    "win": {
      "icon": "resources/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.exe"
    },
    "linux": {
      "category": "Development",
      "icon": "resources/icon.png"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "jkneen",
        "repo": "collaborator-clone"
      }
    ]
  }
}
