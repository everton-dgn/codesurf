    },
    {
      "type": "tool",
      "toolId": "t2"
    }
  ],
  "toolBlocks": [
    {
      "id": "t1",
      "name": "Read",
      "input": "{\\"path\\":\\"a.ts\\"}",
      "status": "done",
      "summary": "Read a.ts",
