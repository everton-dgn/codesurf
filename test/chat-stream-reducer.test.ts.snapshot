          "label": "a.ts",
          "kind": "read"
        }
      ]
    },
    {
      "id": "t2",
      "name": "Grep",
      "input": "{\\"pattern\\":\\"foo\\"}",
      "status": "done",
      "summary": "Searched for foo",
      "commandEntries": [
        {
          "label": "foo",
          "kind": "search"
        }
      ]
    }
  ],
  "cost": 0.012,
  "turns": 1
}
`;

